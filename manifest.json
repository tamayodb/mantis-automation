{
  "manifest_version": 3,
  "name": "Mantis Defect Dashboard",
  "version": "1.0.0",
  "description": "Auto-extract Mantis tickets and generate SQA Defect Management Dashboard",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
